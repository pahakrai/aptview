# ============================================================================
# AI Governance Platform — Environment Variables
# ============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://aigov:aigov123@localhost:5432/aigov

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT (Auth)
# ---------------------------------------------------------------------------
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# API Keys (for external integrations)
# ---------------------------------------------------------------------------
API_KEY_HEADER=x-api-key
ADMIN_API_KEY=dev-admin-key-change-in-production

# ---------------------------------------------------------------------------
# GitHub Integration
# ---------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Jira / Linear Integration
# ---------------------------------------------------------------------------
JIRA_API_TOKEN=
JIRA_BASE_URL=https://your-domain.atlassian.net
LINEAR_API_KEY=

# ---------------------------------------------------------------------------
# Docker Sandbox (ephemeral code analysis)
# ---------------------------------------------------------------------------
SANDBOX_IMAGE=node:20-alpine
SANDBOX_TIMEOUT_MS=30000
SANDBOX_MEMORY_LIMIT_MB=512

# ---------------------------------------------------------------------------
# LLM (for decomposition engine)
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-dev-placeholder
ANTHROPIC_API_KEY=sk-dev-placeholder
