{
  "name": "aigov",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start": "nx run-many --target=serve --all",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "nx format:write",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "dev": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:infra": "docker compose -f docker-compose.infra.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.infra.yml down",
    "db:generate": "yarn workspace backend db:generate",
    "db:migrate": "yarn workspace backend db:migrate",
    "db:seed": "yarn workspace backend db:seed",
    "db:push": "yarn workspace backend db:push",
    "db:studio": "yarn workspace backend db:studio",
    "db:reset:docker": "bash scripts/db-reset.sh docker"
  },
  "dependencies": {
    "dotenv": "^16.3.0",
    "drizzle-kit": "^0.21.0",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@nx/eslint": "19.8.0",
    "@nx/jest": "19.8.0",
    "@nx/nest": "19.8.0",
    "@nx/node": "19.8.0",
    "@nx/react": "19.8.0",
    "@nx/web": "19.8.0",
    "@nx/workspace": "19.8.0",
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "nx": "19.8.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
